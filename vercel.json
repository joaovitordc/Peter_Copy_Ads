{
  "version": 2,
  "builds": [
    {
      "src": "web/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "scripts/**",
          "config.json",
          "planilhas_padrao/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "web/app.py"
    }
  ]
}
