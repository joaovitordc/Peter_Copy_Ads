# Hospedagem de imagens (obrigatorio)
# Crie uma chave gratuita em: https://api.imgbb.com/
IMGBB_API_KEY=sua_chave_aqui

# Traducao de titulos Etsy -> portugues + identificacao de tipo (Q1/KITN)
# Modelo: GPT-4o-mini, ~US$0.0001 por chamada, ~1s de latencia
# Migrado de Gemini Flash em 28/04/2026 apos 8/39 falhas com erro 503.
# Crie em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Modo "Links + Imagens" (planilha com URLs + imagens ja preenchidas) nao precisa
# de nenhuma chave abaixo. Apenas o modo "So Links" precisa de UMA das duas:

# Opcao 1 (recomendada): Firecrawl - scraping autonomo da Etsy
# Free tier: 5 calls/dia. Crie em: https://www.firecrawl.dev/
FIRECRAWL_API_KEY=fc-...

# Opcao 2: Etsy Open API oficial (requer aprovacao manual da Etsy, pode demorar
# ou ser rejeitada se o caso de uso parecer "republicar listings em outros marketplaces")
# Crie em: https://www.etsy.com/developers/register
ETSY_API_KEY=keystring:shared_secret

# Filtro de imagens via Gemini 2.5 Flash Vision (~US$0.05/lote tipico)
# Detecta automaticamente imagens que NAO sao quadros (texto, instrucoes,
# video posters) e filtra elas antes de irem para a Shopee.
# NAO mais usado pra traducao - migrado pra GPT-4o-mini (OPENAI_API_KEY acima).
# Crie chave gratuita em: https://aistudio.google.com/apikey
# Se ausente: filtro de imagens desabilitado, comportamento atual mantido.
GEMINI_API_KEY=...

# (Opcionais) Tunings do Firecrawl - defaults bons para a maioria dos casos:
# FIRECRAWL_MAX_PARALLEL=5
# FIRECRAWL_POLL_INTERVAL=15
# FIRECRAWL_TIMEOUT=600         # 10 min por onda (schema atual e complexo)
# FIRECRAWL_MAX_CREDITS=1500    # creditos por extracao; aumente se ver "max credits"

# Banco de SKUs em uso (substitui skus_em_uso.json local na Vercel).
# Provisionado via Vercel Marketplace -> Supabase (auto-injeta as 2 vars abaixo).
# Sem essas vars, o sistema cai pro arquivo local skus_em_uso.json (dev mode).
#
# Setup:
#   1. https://vercel.com/dashboard > seu projeto > Storage > Create Database > Supabase
#   2. Rodar scripts/supabase_schema.sql no SQL Editor do Supabase (uma vez so)
#   3. Rodar scripts/migrate_to_supabase.py local (depois de baixar as env vars
#      com `vercel env pull`) pra subir os SKUs existentes do JSON pro banco
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
